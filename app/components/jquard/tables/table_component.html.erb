<div class="jq-card">
  <% if table.searchable? %>
    <div class="jq-table-toolbar">
      <%= form_with url: search_url, method: :get, class: "jq-search" do |form| %>
        <% query_params.except(:q, :page).each do |key, value| %>
          <%= form.hidden_field key, value: value %>
        <% end %>
        <%= helpers.jquard_icon("magnifying-glass", css_class: "jq-search-icon") %>
        <%= form.search_field :q, value: query_params[:q], placeholder: "Search",
              class: "jq-search-input", autocomplete: "off" %>
      <% end %>
    </div>
  <% end %>

  <div class="jq-table-scroll">
    <table class="jq-table">
      <thead>
        <tr>
          <% table.columns.each do |column| %>
            <th>
              <% if column.sortable? %>
                <%= link_to sort_url(column), class: "jq-sort-link" do %>
                  <span><%= column.label %></span>
                  <%= helpers.jquard_icon(sort_icon(column), css_class: "jq-sort-icon") %>
                <% end %>
              <% else %>
                <%= column.label %>
              <% end %>
            </th>
          <% end %>
          <% if table.record_actions.any? %>
            <th class="jq-actions-header"></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% result.records.each do |record| %>
          <tr>
            <% table.columns.each do |column| %>
              <td><%= render column.component_class.new(column: column, record: record) %></td>
            <% end %>
            <% if table.record_actions.any? %>
              <td class="jq-row-actions">
                <% table.record_actions.each do |action| %>
                  <%= render action.component_class.new(action: action, resource: resource, record: record) %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
        <% if result.records.empty? %>
          <tr>
            <td colspan="<%= table.columns.size + (table.record_actions.any? ? 1 : 0) %>" class="jq-empty-state">No records found</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="jq-table-footer">
    <nav class="jq-pagination" aria-label="Pagination">
      <span class="jq-pagination-overview">
        Showing <%= result.from %> to <%= result.to %> of <%= result.total_count %> results
      </span>

      <div class="jq-pagination-per-page">
        <%= form_with url: search_url, method: :get do |form| %>
          <% query_params.except(:per_page, :page).each do |key, value| %>
            <%= form.hidden_field key, value: value %>
          <% end %>
          <label class="jq-input-group">
            <span class="jq-input-group-prefix">Per page</span>
            <%= form.select :per_page,
                  options_for_select(Jquard::Tables::Query::PER_PAGE_OPTIONS, result.per_page),
                  {}, class: "jq-per-page-select", data: { jq_autosubmit: true } %>
          </label>
        <% end %>
      </div>

      <ol class="jq-pagination-items">
        <% if result.page > 1 %>
          <li class="jq-pagination-item">
            <%= link_to page_url(result.page - 1), class: "jq-pagination-item-btn", aria: { label: "Previous" } do %>
              <%= helpers.jquard_icon("chevron-left", css_class: "jq-pagination-icon") %>
            <% end %>
          </li>
        <% end %>

        <% page_items.each do |item| %>
          <% if item == :gap %>
            <li class="jq-pagination-item jq-pagination-item--disabled">
              <span class="jq-pagination-item-btn"><span class="jq-pagination-item-label">&hellip;</span></span>
            </li>
          <% else %>
            <li class="<%= class_names("jq-pagination-item", "jq-pagination-item--active" => item == result.page) %>">
              <%= link_to page_url(item), class: "jq-pagination-item-btn" do %>
                <span class="jq-pagination-item-label"><%= item %></span>
              <% end %>
            </li>
          <% end %>
        <% end %>

        <% if result.page < result.pages %>
          <li class="jq-pagination-item">
            <%= link_to page_url(result.page + 1), class: "jq-pagination-item-btn", aria: { label: "Next" } do %>
              <%= helpers.jquard_icon("chevron-right", css_class: "jq-pagination-icon") %>
            <% end %>
          </li>
        <% end %>
      </ol>
    </nav>
  </div>
</div>
