<header class="jq-page-header">
  <h1 class="jq-page-title"><%= @resource.navigation_label %></h1>
</header>

<%= turbo_frame_tag "jquard-table", data: { turbo_action: "advance" } do %>
  <%= render Jquard::Tables::TableComponent.new(
        table: @table,
        resource: @resource,
        result: @result,
        query_params: @query_params
      ) %>
<% end %>
