<header class="jq-page-header">
  <h1 class="jq-page-title"><%= @resource.navigation_label %></h1>
</header>

<div class="jq-card">
  <table class="jq-table-skeleton">
    <thead>
      <tr>
        <% @resource.model.column_names.each do |column| %>
          <th><%= column %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @records.each do |record| %>
        <tr>
          <% @resource.model.column_names.each do |column| %>
            <td><%= record.public_send(column) %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
