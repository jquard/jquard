<h1><%= @resource.model.model_name.human.pluralize %></h1>

<table border="1">
  <thead>
    <tr>
      <% @resource.model.column_names.each do |column| %>
        <th><%= column %></th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @records.each do |record| %>
      <tr>
        <% @resource.model.column_names.each do |column| %>
          <td><%= record.public_send(column) %></td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
