<% content_for :heading, "Resend confirmation instructions" %>

<%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "jq-auth-form" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="jq-field">
    <%= f.label :email, "Email address", class: "jq-label" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email), class: "jq-input" %>
  </div>

  <%= f.submit "Resend confirmation instructions", class: "jq-btn jq-btn--primary jq-btn--block" %>
<% end %>

<%= render "devise/shared/links" %>
