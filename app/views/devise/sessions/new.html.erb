<% content_for :heading, "Sign in" %>

<% if devise_mapping.registerable? %>
  <% content_for :subheading do %>
    or <%= link_to "sign up for an account", new_registration_path(resource_name), class: "jq-link" %>
  <% end %>
<% end %>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "jq-auth-form" }) do |f| %>
  <div class="jq-field">
    <%= f.label :email, "Email address", class: "jq-label" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "jq-input" %>
  </div>

  <div class="jq-field">
    <div class="jq-label-row">
      <%= f.label :password, class: "jq-label" %>
      <% if devise_mapping.recoverable? %>
        <%= link_to "Forgot password?", new_password_path(resource_name), class: "jq-link", tabindex: -1 %>
      <% end %>
    </div>
    <%= f.password_field :password, autocomplete: "current-password", class: "jq-input" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="jq-field-inline">
      <%= f.check_box :remember_me, class: "jq-checkbox" %>
      <%= f.label :remember_me, class: "jq-label" %>
    </div>
  <% end %>

  <%= f.submit "Sign in", class: "jq-btn jq-btn--primary jq-btn--block" %>
<% end %>
