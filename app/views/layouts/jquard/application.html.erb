<!DOCTYPE html>
<html>
<head>
  <title><%= Jquard.config.brand_name %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= jquard_theme_style %>
  <%= yield :head %>

  <%= stylesheet_link_tag "jquard/application", media: "all" %>
  <%= javascript_include_tag "turbo.min", type: "module" %>
  <%= javascript_include_tag "jquard/confirm", type: "module" %>
</head>
<body class="jq-body">
  <div class="jq-shell">
    <aside class="jq-sidebar">
      <div class="jq-sidebar-header">
        <span class="jq-brand"><%= Jquard.config.brand_name %></span>
      </div>

      <nav class="jq-sidebar-nav">
        <% jquard_navigation.each do |group, resources| %>
          <div>
            <% if group %>
              <p class="jq-nav-group-label"><%= group %></p>
            <% end %>
            <ul class="jq-nav-items">
              <% resources.each do |resource| %>
                <li>
                  <%= link_to resource_path(resource.slug),
                        class: class_names("jq-nav-item", "jq-nav-item--active" => params[:resource_slug] == resource.slug) do %>
                    <%= jquard_icon(resource.navigation_icon, css_class: "jq-nav-item-icon") %>
                    <span><%= resource.navigation_label %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </nav>
    </aside>

    <div class="jq-main">
      <header class="jq-topbar">
        <nav class="jq-breadcrumbs">
          <% if @resource %>
            <span><%= @resource.navigation_label %></span>
          <% end %>
        </nav>
      </header>

      <main class="jq-content">
        <% if notice.present? %>
          <div class="jq-toast" role="status">
            <%= jquard_icon("check-circle", css_class: "jq-toast-icon") %>
            <span><%= notice %></span>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </div>

  <dialog id="jquard-confirm-dialog" class="jq-modal">
    <div class="jq-modal-window">
      <div class="jq-modal-icon-circle">
        <%= jquard_icon("trash", css_class: "jq-modal-icon") %>
      </div>
      <h2 class="jq-modal-heading" data-slot="heading"></h2>
      <p class="jq-modal-description" data-slot="description"></p>
      <form method="dialog" class="jq-modal-actions">
        <button value="" class="jq-btn jq-btn--secondary">Cancel</button>
        <button value="confirm" class="jq-btn jq-btn--danger" data-slot="confirm">Confirm</button>
      </form>
    </div>
  </dialog>
</body>
</html>
